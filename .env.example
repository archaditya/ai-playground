# ── LLM Providers ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional third model for Multi-LLM voting (e.g. Groq/Together/Mistral via OpenAI-compatible endpoint)
THIRD_LLM_API_KEY=
THIRD_LLM_BASE_URL=
THIRD_LLM_MODEL=

# ── Vector DB (choose one; defaults to in-memory for local dev) ──
VECTOR_DB_PROVIDER=memory        # memory | pinecone | supabase
PINECONE_API_KEY=
PINECONE_INDEX=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Embeddings ────────────────────────────────────────────────────
EMBEDDINGS_PROVIDER=openai       # openai
EMBEDDINGS_MODEL=text-embedding-3-small

# ── App Config ────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info                  # debug | info | warn | error
RATE_LIMIT_MAX=20               # requests
RATE_LIMIT_WINDOW_MS=60000      # per window (ms)

# ── YouTube RAG (optional) ───────────────────────────────────────
YOUTUBE_API_KEY=
